# Tradovate Demo Credentials
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get credentials from: https://trader.tradovate.com/ → Settings → API Access
# IMPORTANT: Use DEMO credentials, not live.

TRADOVATE_USERNAME=your_demo_username
TRADOVATE_PASSWORD=your_demo_password
TRADOVATE_APP_ID=your_app_name
TRADOVATE_CID=your_client_id
TRADOVATE_SECRET=your_api_secret
TRADOVATE_DEVICE_ID=your_device_id

# Environment — MUST be "demo" for paper trading
# The paper connector will assert and refuse to start if this is "live"
TRADOVATE_ENVIRONMENT=demo

# Safety limits
DAILY_LOSS_LIMIT=500
MAX_POSITION_SIZE=2

# ── IBKR TWS Auto-Launch (Socket API) ──
# TWS/IBC paths — auto-detected on Windows if left blank
IBKR_TWS_PATH=
IBKR_IBC_PATH=

# TWS connection
IBKR_TWS_HOST=127.0.0.1
IBKR_TWS_PORT=7497
IBKR_CLIENT_ID=1

# IBC login credentials (IBC reads these to automate TWS login dialog)
IBKR_USERNAME=your_tws_username
IBKR_PASSWORD=your_tws_password

# Crash recovery
IBKR_AUTO_RESTART=true
IBKR_MAX_RESTART_ATTEMPTS=5

# ── Alerting Configuration ──
# Discord webhook for trade alerts (create via Server Settings → Integrations → Webhooks)
ALERT_DISCORD_WEBHOOK_URL=

# Telegram bot token and chat ID (create bot via @BotFather, get chat_id via @userinfobot)
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
