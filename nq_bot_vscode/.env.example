# Tradovate Demo Credentials
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get credentials from: https://trader.tradovate.com/ → Settings → API Access
# IMPORTANT: Use DEMO credentials, not live.

TRADOVATE_USERNAME=your_demo_username
TRADOVATE_PASSWORD=your_demo_password
TRADOVATE_APP_ID=your_app_name
TRADOVATE_CID=your_client_id
TRADOVATE_SECRET=your_api_secret
TRADOVATE_DEVICE_ID=your_device_id

# Environment — MUST be "demo" for paper trading
# The paper connector will assert and refuse to start if this is "live"
TRADOVATE_ENVIRONMENT=demo

# Safety limits
DAILY_LOSS_LIMIT=500
MAX_POSITION_SIZE=2

# ─────────────────────────────────────────────────────────────────────
# ALERTING & NOTIFICATIONS
# ─────────────────────────────────────────────────────────────────────

# Enabled alert channels (comma-separated)
# Options: console, discord, telegram
# console is always available as fallback
ALERT_CHANNELS=console,discord,telegram

# Discord webhook for rich embeds (optional)
# Get from: Discord Server → Settings → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Telegram Bot API (optional)
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Alert rate limiting: max 1 per event type per N seconds
# EMERGENCY alerts bypass this limit
ALERT_RATE_LIMIT_SECONDS=300
