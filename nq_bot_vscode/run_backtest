"""
Backtest Runner - Multi-Timeframe Edition
============================================
Run the 2-contract scale-out strategy against historical NQ data
across multiple timeframes.

Usage:
    python scripts/run_backtest.py --tv                   # MTF backtest with TradingView CSVs
    python scripts/run_backtest.py --tv --exec-tf 3m      # Use 3m as execution TF
    python scripts/run_backtest.py --sample               # Sample data (pipeline test, single TF)
    python scripts/run_backtest.py --file data/nq.csv     # Specific file (single TF)
"""

import sys, os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))

import asyncio
import argparse
import json
import logging
import random
import sys
import os
from datetime import datetime, timezone, timedelta

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from config.settings import CONFIG
from features.engine import Bar
from data_pipeline.pipeline import DataPipeline, bardata_to_bar
from main import TradingOrchestrator


def generate_sample_bars(num_bars: int = 3000, start_price: float = 20000.0) -> list:
    """Generate NQ-like 1-minute bars for pipeline testing. NOT for strategy validation."""
    bars = []
    price = start_price
    base_time = datetime(2025, 1, 2, 14, 30, tzinfo=timezone.utc)
    trend = 0

    for i in range(num_bars):
        if i % 300 == 0:
            trend = random.choice([-1, 0, 0, 1])

        volatility = random.uniform(1.0, 6.0)
        direction = random.gauss(trend * 0.3, 1.0)
        move = direction * volatility

        if random.random() < 0.005:
            move *= random.uniform(3, 8)

        open_price = price
        close_price = price + move
        high = max(open_price, close_price) + random.uniform(0, volatility * 0.5)
        low = min(open_price, close_price) - random.uniform(0, volatility * 0.5)
        volume = max(int(random.gauss(8000, 3000)), 500)

        if close_price > open_price:
            ask_vol = int(volume * random.uniform(0.5, 0.7))
        else:
            ask_vol = int(volume * random.uniform(0.3, 0.5))
        bid_vol = volume - ask_vol

        bars.append(Bar(
            timestamp=base_time + timedelta(minutes=i),
            open=round(open_price, 2),
            high=round(high, 2),
            low=round(low, 2),
            close=round(close_price, 2),
            volume=volume,
            bid_volume=bid_vol,
            ask_volume=ask_vol,
            delta=ask_vol - bid_vol,
        ))
        price = close_price

    return bars


async def run_backtest_mtf(exec_tf: str = "2m"):
    """Execute multi-timeframe backtest using all available TradingView CSVs."""
    CONFIG.execution.paper_trading = True

    bot = TradingOrchestrator(CONFIG)
    await bot.initialize(skip_db=True)

    # Load multi-timeframe data
    pipeline = DataPipeline(CONFIG)
    tf_bars = pipeline.load_mtf_data()

    if not tf_bars:
        print("ERROR: No CSV files found in data/tradingview/")
        print("Export data from TradingView and place CSVs in that directory.")
        sys.exit(1)

    # Summary
    summary = pipeline.get_mtf_summary(tf_bars)
    print(f"\n{'='*60}")
    print(f"  MULTI-TIMEFRAME BACKTEST")
    print(f"  Execution TF: {exec_tf}")
    print(f"{'='*60}")
    for tf, info in summary.items():
        marker = " <- EXEC" if tf == exec_tf else ""
        print(f"  {tf:>4s}: {info['bars']:>6,} bars | {info['price_range']}{marker}")
    print(f"{'='*60}\n")

    # Verify execution TF data exists
    if exec_tf not in tf_bars:
        print(f"ERROR: No data for execution timeframe '{exec_tf}'")
        print(f"Available timeframes: {', '.join(tf_bars.keys())}")
        sys.exit(1)

    # Create synchronized iterator
    mtf_iterator = pipeline.create_mtf_iterator(tf_bars)
    print(f"Total bars across all timeframes: {len(mtf_iterator):,}")

    # Run
    results = await bot.run_backtest_mtf(mtf_iterator, execution_tf=exec_tf)

    # Print scale-out breakdown
    if results.get("total_trades", 0) > 0:
        print(f"\n  SCALE-OUT BREAKDOWN:")
        print(f"  C1 (fixed target) total PnL:  ${results.get('c1_total_pnl', 0):,.2f}")
        print(f"  C2 (runner) total PnL:         ${results.get('c2_total_pnl', 0):,.2f}")
        print(f"  C2 outperformed C1:            {results.get('c2_outperformed_c1_pct', 0):.1f}% of trades")
        print(f"\n  HTF FILTER IMPACT:")
        print(f"  Signals blocked by HTF:        {results.get('htf_blocked_signals', 0)}")
        print(f"  HTF block rate:                {results.get('htf_block_rate', 0):.1f}%")
        print(f"{'='*60}\n")

    # === EXPORT VISUALIZATION DATA ===
    viz_data = {
        "summary": {
            k: v for k, v in results.items()
            if k not in ("equity_curve", "exec_bars_log", "trade_log",
                         "htf_bias_log", "equity_timestamps")
        },
        "bars": results.get("exec_bars_log", []),
        "trades": results.get("trade_log", []),
        "htf_bias": results.get("htf_bias_log", []),
        "equity_curve": [
            {"equity": eq, "time": ts}
            for eq, ts in zip(
                results.get("equity_curve", []),
                ["start"] + results.get("equity_timestamps", [])
            )
        ],
    }

    output_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
                               "backtest_viz_data.json")
    with open(output_path, "w") as f:
        json.dump(viz_data, f, indent=2, default=str)
    print(f"  Visualization data exported: {output_path}")
    print(f"  Bars: {len(viz_data['bars'])}, Trades: {len(viz_data['trades'])}, HTF snapshots: {len(viz_data['htf_bias'])}")
    print(f"  Open chart.html in a browser to view trades.\n")

    return results


async def run_backtest_single(bars, label: str = ""):
    """Execute single-TF backtest (legacy/sample mode)."""
    CONFIG.execution.paper_trading = True

    bot = TradingOrchestrator(CONFIG)
    await bot.initialize(skip_db=True)

    print(f"\n{'='*60}")
    print(f"  BACKTEST: {label}")
    print(f"  Bars: {len(bars)}")
    if bars:
        print(f"  Range: {bars[0].timestamp} -> {bars[-1].timestamp}")
        print(f"  Strategy: 2x MNQ Scale-Out")
        print(f"  C1 Target: {CONFIG.scale_out.c1_target_min_points}-{CONFIG.scale_out.c1_target_max_points} pts")
        print(f"  Account: ${CONFIG.risk.account_size:,.2f}")
    print(f"{'='*60}\n")

    results = await bot.run_backtest(bars)

    if results.get("total_trades", 0) > 0:
        print(f"\n  SCALE-OUT BREAKDOWN:")
        print(f"  C1 (fixed target) total PnL:  ${results.get('c1_total_pnl', 0):,.2f}")
        print(f"  C2 (runner) total PnL:         ${results.get('c2_total_pnl', 0):,.2f}")
        print(f"  C2 outperformed C1:            {results.get('c2_outperformed_c1_pct', 0):.1f}% of trades")
        print(f"{'='*60}\n")

    return results


def main():
    parser = argparse.ArgumentParser(description="NQ Bot - Backtest Runner (MTF)")
    parser.add_argument("--sample", action="store_true", help="Use generated sample data (single TF)")
    parser.add_argument("--tv", action="store_true", help="Multi-timeframe backtest with TradingView CSVs")
    parser.add_argument("--file", type=str, help="Path to specific CSV file (single TF)")
    parser.add_argument("--bars", type=int, default=3000, help="Number of sample bars")
    parser.add_argument("--exec-tf", type=str, default="2m",
                       help="Execution timeframe for MTF backtest (default: 2m)")
    parser.add_argument("--no-hc", action="store_true",
                       help="Disable high-conviction filter (pass all signals)")
    args = parser.parse_args()

    if args.no_hc:
        import config.constants as _c
        import main as _m
        _c.HIGH_CONVICTION_MIN_SCORE = 0.0
        _c.HIGH_CONVICTION_MAX_STOP_PTS = 9999.0
        _m.HIGH_CONVICTION_MIN_SCORE = 0.0
        _m.HIGH_CONVICTION_MAX_STOP_PTS = 9999.0

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s | %(levelname)-8s | %(message)s",
        datefmt="%H:%M:%S",
    )

    if args.tv:
        # === MULTI-TIMEFRAME BACKTEST ===
        asyncio.run(run_backtest_mtf(exec_tf=args.exec_tf))

    elif args.file:
        pipeline = DataPipeline(CONFIG)
        bar_data = pipeline.tv_importer.import_file(args.file)
        if not bar_data:
            print(f"ERROR: No data loaded from {args.file}")
            sys.exit(1)
        summary = pipeline.get_data_summary(bar_data)
        print(f"Data summary: {summary}")
        bars = pipeline.convert_to_feature_bars(bar_data)
        asyncio.run(run_backtest_single(bars, label=f"TradingView: {args.file}"))

    elif args.sample or True:
        print("Generating sample data (for pipeline testing only)...")
        bars = generate_sample_bars(args.bars)
        asyncio.run(run_backtest_single(bars, label=f"Sample Data ({args.bars} bars)"))


if __name__ == "__main__":
    main()
