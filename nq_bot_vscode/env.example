# ── NQ Trading Bot — Environment Variables ──────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file itself.

# ── Tradovate ────────────────────────────────────────────────
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_CID=0
TRADOVATE_SECRET=
TRADOVATE_DEVICE_ID=nq-bot-01
TRADOVATE_ENV=demo                # demo | live

# ── Database (PostgreSQL) ────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=nq_trading
PG_USER=nq_bot
PG_PASSWORD=

# ── Data Pipeline ────────────────────────────────────────────
TV_EXPORT_DIR=./data/tradingview  # TradingView CSV export directory
